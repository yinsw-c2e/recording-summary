# LLM
# If LLM_PROVIDER is omitted, the app uses DeepSeek when DEEPSEEK_API_KEY exists,
# otherwise it falls back to the local mock provider for development.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# Storage
DATA_DIR=./data
TIME_ZONE=Asia/Shanghai

# Public deployment
PUBLIC_BASE_URL=https://your-domain.example
APP_PASSWORD=
SESSION_SECRET=

# Local speech providers
STT_MODE=local
WHISPER_BIN=whisper
WHISPER_MODEL=large-v3
WHISPER_MODEL_DIR=./data/whisper_models
TTS_PROVIDER=macos-say

# Mac worker. On the cloud server set STT_MODE=remote-worker and WORKER_TOKEN.
# On the Mac set WORKER_SERVER_URL to the cloud URL and reuse the same WORKER_TOKEN.
WORKER_TOKEN=
WORKER_ID=mac-whisper-worker
WORKER_SERVER_URL=http://localhost:8787
WORKER_POLL_MS=5000
WORKER_TEMP_DIR=./data/worker_tmp

# Server
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
